flowchart LR

  %% =========================
  %% B2B MVP SYSTEM (WITH n8n) - SIMPLIFIED
  %% Removed:
  %% - GA4 -> Sheets Summary branch
  %% - Daily Backup Drive branch
  %% Keep:
  %% - Website UI + Form + UTM capture
  %% - Anonymous tracking: dataLayer -> GTM -> GA4
  %% - n8n lead intake: Webhook -> reCAPTCHA verify -> Sheets -> Telegram/Email
  %% =========================

  subgraph TRAFFIC["NGUỒN TRUY CẬP"]
    SEO["SEO / Google / AI Overview"]
    ADS["Ads / Social / Referral"]
  end

  subgraph USER["NGƯỜI DÙNG"]
    VIS["Khách truy cập B2B"]
  end

  subgraph WEB["WEBSITE B2B (FRONTEND)"]
    PAGES["Pages: Home / Authority / Category-Product / Contact / Thank-you"]
    UI["UI Actions: CTA sticky / Click Hotline-Zalo / Download PDF (opt)"]
    UTM["UTM Capture: utm_source, utm_medium, utm_campaign, utm_content, utm_term"]
    CAPTCHA["reCAPTCHA v3 (ẩn)\nGenerate token on submit"]
    FORM["Form báo giá (PII)"]
  end

  subgraph TRACK["TRACKING ẨN DANH (NON-PII)"]
    DL["dataLayer events (NON-PII)\nclick_tel, click_zalo, file_download(opt), generate_lead"]
    GTM["Google Tag Manager (Triggers + Tags)"]
    GA4["GA4 (Reports + Conversions)"]
  end

  subgraph N8N["n8n AUTOMATION (LEAD INTAKE)"]
    WH["Webhook Node (Receive payload)\n(PII + UTM + landing_page + recaptcha_token)"]
    RCHECK["Verify reCAPTCHA token\n(siteverify)"]
    SHEET_LEADS["Google Sheets Node (Append lead row)"]
    TG["Telegram Node (Realtime notify)"]
    EMAIL["Email Node (Optional backup notify)"]
    LOG["Error/Log Node (optional)"]
  end

  subgraph STORAGE["DATA STORAGE"]
    SHEET["Google Sheets\nTab: Leads"]
  end

  %% Traffic -> Website
  SEO -->|"Traffic vào web"| VIS
  ADS -->|"Traffic vào web"| VIS
  VIS -->|"Mở website"| PAGES
  PAGES -->|"Hiển thị UI/CTA"| UI

  %% UTM capture on website
  PAGES -->|"Đọc UTM từ URL"| UTM
  UTM -->|"Gắn UTM vào payload form"| FORM

  %% reCAPTCHA token
  FORM -->|"On submit: request reCAPTCHA v3 token"| CAPTCHA
  CAPTCHA -->|"Attach recaptcha_token into payload"| FORM

  %% Anonymous tracking (kept)
  UI -->|"Click hotline/zalo/download"| DL
  FORM -->|"Submit success => generate_lead (NON-PII)"| DL
  DL -->|"Push events"| GTM
  GTM -->|"Send events"| GA4

  %% Lead pipeline (n8n)
  FORM -->|"POST payload to webhook"| WH
  WH -->|"Verify reCAPTCHA before processing"| RCHECK
  RCHECK -->|"Pass -> process lead"| SHEET_LEADS
  RCHECK -->|"Fail -> log error"| LOG
  SHEET_LEADS -->|"Lead saved"| SHEET
  SHEET_LEADS -->|"Notify realtime"| TG
  SHEET_LEADS -->|"Backup notify"| EMAIL