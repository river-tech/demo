flowchart LR

  subgraph TRAFFIC["NGUỒN TRUY CẬP"]
    SEO["SEO / Google / AI Overview"]
    ADS["Ads / Social / Referral"]
  end

  subgraph USER["NGƯỜI DÙNG"]
    VIS["Khách truy cập B2B"]
  end

  subgraph WEB["WEBSITE B2B (FRONTEND)"]
    PAGES["Pages: Home / Authority / Category-Product / Contact / Thank-you"]
    UI["UI Actions: CTA sticky / Click Hotline-Zalo / Download PDF (opt)"]

    UTMSTORE["First-touch UTM Store\nCookie/LocalStorage\n(ft_utm_* + ft_landing_page + ft_ts)"]
    GAID["Get GA4 client_id\n(from _ga cookie)"]

    CAPTCHA["reCAPTCHA v3 (ẩn)\nGenerate token on submit"]
    FORM["Form báo giá (PII)\nAttach: ft_utm_* + ga_client_id + recaptcha_token"]
  end

  subgraph TRACK["TRACKING ẨN DANH (NON-PII)"]
    DL["dataLayer events (NON-PII)\nclick_tel, click_zalo, file_download(opt), generate_lead"]
    GTM["GTM (Triggers + Tags)"]
    GA4["GA4 (Reports + Conversions)"]
  end

  subgraph N8N["n8n AUTOMATION (LEAD INTAKE)"]
    WH["Webhook Receive payload"]
    RCHECK["Verify reCAPTCHA token\n(siteverify)"]
    REGEX["Validation (Regex)\nphone/email/quantity…"]
    DEDUPE["Dedupe check\nLookup phone/email in Sheets\n(time window e.g. 24h)"]
    SHEET_LEADS["Append row -> Sheets (Leads)"]
    TG["Telegram notify (realtime)"]
    EMAIL["Email notify (optional)"]
    LOG["Error/Drop Log (optional)"]
  end

  subgraph STORAGE["DATA STORAGE"]
    SHEET["Google Sheets - Tab Leads"]
  end

  SEO -->|"Traffic"| VIS
  ADS -->|"Traffic"| VIS
  VIS -->|"Open site"| PAGES
  PAGES -->|"Render UI"| UI

  %% UTM first-touch store
  PAGES -->|"Read UTM from URL (if exists)"| UTMSTORE
  UTMSTORE -->|"Persist first-touch UTM"| FORM

  %% GA4 client_id capture
  PAGES -->|"Read GA client_id from _ga cookie"| GAID
  GAID -->|"Attach ga_client_id"| FORM

  %% reCAPTCHA
  FORM -->|"On submit -> get token"| CAPTCHA
  CAPTCHA -->|"Attach token"| FORM

  %% Anonymous tracking
  UI -->|"Clicks"| DL
  FORM -->|"Submit success -> generate_lead (NON-PII)"| DL
  DL -->|"Push events"| GTM
  GTM -->|"Send"| GA4

  %% Lead pipeline
  FORM -->|"POST payload"| WH
  WH -->|"Verify captcha"| RCHECK
  RCHECK -->|"Fail -> drop/log"| LOG
  RCHECK -->|"Pass"| REGEX
  REGEX -->|"Fail -> drop/log"| LOG
  REGEX -->|"Pass"| DEDUPE
  DEDUPE -->|"Duplicate -> drop/log"| LOG
  DEDUPE -->|"Unique -> write"| SHEET_LEADS
  SHEET_LEADS -->|"Row added"| SHEET
  SHEET_LEADS -->|"Notify"| TG
  SHEET_LEADS -->|"Email (opt)"| EMAIL